# Exotel (Indian telephony)
EXOTEL_SID=              # Account SID (in API URL; e.g. eknumber1)
EXOTEL_API_KEY=          # API Key = Basic auth username (from API Settings; if empty, EXOTEL_SID is used)
EXOTEL_TOKEN=             # API Token = Basic auth password
EXOTEL_VIRTUAL_NUMBER=    # Your Exotel virtual number
EXOTEL_SUBDOMAIN=api.exotel.com

# Google Cloud (use one of the two below)
# Local: path to the JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# Render/cloud: paste the full JSON key as one line (no file upload)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_SHEETS_ID=

# Server
PORT=3000

# Optional: base URL for webhook callbacks (e.g. https://your-app.railway.app)
BASE_URL=
